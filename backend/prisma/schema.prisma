generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {  
    id Int @id @default(autoincrement())
    firstName String
    lastName String
    department String
    email String @unique
    hashedPassword String
    createdAt DateTime @default(now())
    chatHistory ChatHistory[]
}

model ChatHistory {
    id Int @id @default(autoincrement())
    userId Int
    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
    message String
    answer String
    sources String[]
    createdAt DateTime @default(now())
    @@index([userId])
}
